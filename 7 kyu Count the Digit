function nbDig(n, d) {
  let count = 0;

  for (let i = 0; i <= n; i++) {
    count += (i * i).toString().split(d).length - 1;
  }

  return count;
}
//another solution
function nbDig(n, d) {
  if (n < 0 || d < 0 || d > 9) return 0;

  let count = 0;

  for (let i = 0; i <= n; i++) {
    let square = String(i * i);

    for (let char of square) {
      if (char === d.toString()) {
        count++;
      }
    }
  }

  return count;
}

