function seqToOne(n) {
    let seq = [];
    
    if (n > 0) {
        // If n is positive, count down from n to 1
        for (let i = n; i >= 1; i--) {
            seq.push(i);
        }
    } else if (n < 0) {
        // If n is negative, count up from n to 1
        for (let i = n; i <= 1; i++) {
            seq.push(i);
        }
    } else {
        // If n is 0, return [0, 1]
        seq.push(0, 1);
    }
    
    return seq;
}
