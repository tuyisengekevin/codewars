function solution(arr_val, arr_unit) {
  const massUnits = {
    kg: 1,
    g: 1e-3,
    mg: 1e-6,
    "μg": 1e-9,
    lb: 0.453592
  };

  const distanceUnits = {
    m: 1,
    cm: 1e-2,
    mm: 1e-3,
    "μm": 1e-6,
    ft: 0.3048
  };

  const G = 6.67e-11;

  const m1 = arr_val[0] * massUnits[arr_unit[0]];
  const m2 = arr_val[1] * massUnits[arr_unit[1]];
  const r = arr_val[2] * distanceUnits[arr_unit[2]];

  return G * m1 * m2 / (r * r);
}
